{
  "name": "muenchen-plantscht",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "preview": "vp preview",
    "deploy": "vp build && wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e": "playwright test",
    "prepare": "vp config"
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.70.0",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "wrangler": "^4.112.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.13.1"
}
